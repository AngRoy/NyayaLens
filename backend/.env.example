# ---------------------------------------------------------------------------
# NyayaLens backend — environment configuration
# Copy to `.env` and fill in the blanks.  `.env` is gitignored.
# ---------------------------------------------------------------------------

# -- Core --
NYAYALENS_ENV=dev                          # dev | staging | prod
NYAYALENS_LOG_LEVEL=INFO

# -- Gemini API --
# https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL_EXPLAIN=gemini-flash-latest   # low-temp, cheap, fast
GEMINI_MODEL_SCHEMA=gemini-pro-latest      # structured-output for schema detection
GEMINI_TEMPERATURE=0.2
GEMINI_DAILY_TOKEN_BUDGET_PER_ORG=1000000  # per-org safety cap

# -- Firebase project (real, used when emulators are not set) --
GOOGLE_CLOUD_PROJECT=
FIREBASE_STORAGE_BUCKET=                   # typically <project>.appspot.com

# -- Firebase emulators (set automatically by `firebase emulators:start`) --
# Leave these blank for prod; the emulator suite injects them locally.
# FIRESTORE_EMULATOR_HOST=localhost:8080
# FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
# FIREBASE_STORAGE_EMULATOR_HOST=localhost:9199

# -- Service account (prod only; leave blank in dev) --
# Set to the path of a GCP service-account JSON file, or leave blank to use
# Application Default Credentials.
GOOGLE_APPLICATION_CREDENTIALS=

# -- Backend server --
HOST=127.0.0.1
PORT=8000
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5000

# -- Feature flags --
ENABLE_RESPONSE_CACHE=true                 # pre-computed demo cache per ADR 0005
ENABLE_GROUNDING_VALIDATOR=true            # mandatory in prod; off for specific tests

# ===========================================================================
# NyayaLens — repo-wide gitignore
# ===========================================================================

# --- Secrets & environment ---
.env
.env.*
!.env.example
*.secret
service-account-*.json
firebase-adminsdk-*.json
gemini-api-key*

# --- Real PII anchor data (design doc §6.4) stays local, NEVER committed ---
shared/sample_data/placement_real_anchor.csv
shared/sample_data/*_real_*.csv
shared/sample_data/*_real_*.xlsx

# --- Generated JSON Schemas (regenerated by contract-test workflow) ---
shared/schemas/

# ===========================================================================
# Python / backend
# ===========================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
wheels/
eggs/
*.egg-info/
.installed.cfg
*.egg
pip-wheel-metadata/

# Virtual envs
.venv/
venv/
env/
ENV/

# Testing & tooling
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/
.cache

# IPython / Jupyter
.ipynb_checkpoints/
*.ipynb

# ===========================================================================
# Dart / Flutter / frontend
# ===========================================================================
frontend/.dart_tool/
frontend/.flutter-plugins
frontend/.flutter-plugins-dependencies
frontend/.packages
frontend/.pub-cache/
frontend/.pub/
frontend/build/
# frontend/pubspec.lock
frontend/.metadata
frontend/android/
frontend/ios/
frontend/linux/
frontend/macos/
frontend/windows/
frontend/coverage/
# We build web-first; platform folders are regenerated as needed.

# Generated files (freezed, json_serializable)
**/*.g.dart
**/*.freezed.dart
!**/*.generated.dart

# ===========================================================================
# Node (shared tooling, CI scripts)
# ===========================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/

# ===========================================================================
# Firebase
# ===========================================================================
.firebase/
firebase-debug.log
firebase-debug.*.log
firestore-debug.log
ui-debug.log
pubsub-debug.log
*.local.json
infra/firebase-emulator-data/

# ===========================================================================
# Cloud / GCP
# ===========================================================================
gha-creds-*.json

# ===========================================================================
# Editors & OS
# ===========================================================================
.idea/
.vscode/
!.vscode/settings.json.example
!.vscode/launch.json.example
*.iml
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ===========================================================================
# Build artifacts
# ===========================================================================
*.log
logs/
tmp/
temp/
.claude/
AGENTS.md

# ===========================================================================
# Production stakes hardening (Cloud Run + Firebase Hosting are live)
# ===========================================================================

# --- Catch-all for credential JSON shapes ---
*-credentials.json
*-creds.json
*-svcacct.json
*-sa.json
application_default_credentials*.json
gcloud-config*.json
firebase-tools-token.json
.firebase-tools-token.json

# --- TLS / signing material ---
*.pem
*.key
*.pfx
*.p12
*.cer
*.crt
*.jks
*.keystore

# --- Cloud Run / IaC state ---
*.tfstate
*.tfstate.backup
*.tfstate.*
.terraform/
infra/cloud-run/*.local.yaml
infra/**/*.local.yaml

# --- Diagram + Office app temp files ---
*.drawio.bkp
~$*.docx
~$*.xlsx
~$*.pptx

# --- Coverage at repo root (not just frontend) ---
/coverage/
lcov.info
.nyc_output/

# --- Local-only dart-define files ---
**/dart_defines.json
**/.dart_defines.json
